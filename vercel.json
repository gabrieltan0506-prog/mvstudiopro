{
  "buildCommand": "pnpm exec vite build",
  "outputDirectory": "server/_core/public",
  "headers": [
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/business",
      "destination": "https://mvstudiopro.fly.dev/api/business"
    },
    {
      "source": "/api/env-status",
      "destination": "https://mvstudiopro.fly.dev/api/jobs?op=envStatus"
    },
    {
      "source": "/api/diag/providers",
      "destination": "https://mvstudiopro.fly.dev/api/diag/providers"
    },
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/:path((?!api/|assets/|.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}
