{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "git": {
    "deploymentEnabled": true
  },
  "github": {
    "enabled": true
  },
  "buildCommand": "pnpm exec vite build",
  "outputDirectory": "client/dist",
  "headers": [
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/oauth/callback",
      "destination": "https://mvstudiopro.fly.dev/api/oauth/callback"
    },
    {
      "source": "/api/:path*",
      "destination": "https://mvstudiopro.fly.dev/api/:path*"
    },
    {
      "source": "/:path((?!api/|assets/|.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}
