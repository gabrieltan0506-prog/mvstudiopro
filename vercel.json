{
  "buildCommand": "pnpm exec vite build",
  "outputDirectory": "client/dist",
  "headers": [
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/ext/reverse-geocode",
      "destination": "https://api.bigdatacloud.net/data/reverse-geocode-client"
    },
    {
      "source": "/api/ext/open-meteo",
      "destination": "https://geocoding-api.open-meteo.com/v1/search"
    },
    {
      "source": "/api/oauth/callback",
      "destination": "https://mvstudiopro.fly.dev/api/oauth/callback"
    },
    {
      "source": "/api/:match*",
      "destination": "https://mvstudiopro.fly.dev/api/:match*"
    },
    {
      "source": "/:path((?!api/|assets/|.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}
